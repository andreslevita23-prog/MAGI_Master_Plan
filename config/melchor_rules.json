{
  "module": "MELCHOR",
  "version": "v1.0",
  "mode": "deterministic",
  "sessions": {
    "allowed": ["london", "new_york", "overlap"],
    "utc_windows": [
      {
        "name": "london",
        "start": "07:00",
        "end": "16:00"
      },
      {
        "name": "new_york",
        "start": "12:00",
        "end": "21:00"
      }
    ]
  },
  "risk": {
    "max_risk_percent_per_trade": 0.1,
    "max_open_trades": 1,
    "min_rr": 1.5,
    "preferred_rr": 2.0,
    "max_consecutive_losses": 5,
    "daily_drawdown_notify_percent": 0.7,
    "daily_drawdown_block_percent": 1.0
  },
  "news": {
    "blocked_impact": "high",
    "blocked_currencies": ["USD", "EUR", "GBP"],
    "window_minutes_before": 30,
    "window_minutes_after": 30
  },
  "trade_management": {
    "move_sl_to_breakeven_at_tp_progress": 0.5,
    "after_breakeven": "progressive_trailing_stop"
  },
  "market": {
    "max_spread_pips": 2.0,
    "min_sl_pips": 5,
    "max_sl_pips": 35
  },
  "data_quality": {
    "block_on_missing_critical_data": true
  }
}
